{% assign repo_parts = include.repository | split: '/' %}
{% assign repo_owner = repo_parts[0] %}
{% assign repo_name = repo_parts[1] %}
{% assign card_id = include.repository | replace: '/', '-' %}

<div style="width: 280px;">
  <a href="https://github.com/{{ include.repository }}" target="_blank" rel="noopener noreferrer" style="text-decoration: none;">
    <div class="card hoverable" id="repo-{{ card_id }}" style="height: 160px; padding: 1.25rem; display: flex; flex-direction: column; justify-content: space-between;">
      <div>
        <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem;">
          <i class="fa-solid fa-book" style="color: var(--global-theme-color); font-size: 0.9rem;"></i>
          <span style="font-weight: 600; font-size: 0.95rem;">{{ repo_owner }}/{{ repo_name }}</span>
        </div>
        <p class="repo-desc" style="font-size: 0.82rem; color: var(--global-text-color-light); margin: 0; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">Loading...</p>
      </div>
      <div style="display: flex; align-items: center; gap: 1.25rem; font-size: 0.8rem; color: var(--global-text-color-light);">
        <span><i class="fa-regular fa-star me-1"></i><span class="repo-stars">–</span></span>
        <span><i class="fa-solid fa-code-fork me-1"></i><span class="repo-forks">–</span></span>
      </div>
    </div>
  </a>
</div>

<script>
  fetch('https://api.github.com/repos/{{ include.repository }}')
    .then(function(r) { return r.json(); })
    .then(function(data) {
      var card = document.getElementById('repo-{{ card_id }}');
      if (!card) return;
      card.querySelector('.repo-desc').textContent = data.description || '';
      card.querySelector('.repo-stars').textContent = data.stargazers_count !== undefined ? data.stargazers_count : '–';
      card.querySelector('.repo-forks').textContent = data.forks_count !== undefined ? data.forks_count : '–';
    })
    .catch(function() {});
</script>
